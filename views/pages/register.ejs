<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Little Hearts Therapy</title>
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="auth-page">
    <div class="auth-card" style="max-width:520px;">
      <div class="auth-card__logo">
        <div class="auth-card__logo-icon" aria-hidden="true">🌿</div>
        <h1>Create your account</h1>
        <p>Join the Little Hearts community</p>
      </div>

      <%- include('../partials/flash') %>

      <form action="/auth/register" method="POST" id="register-form" aria-label="Registration form">
        <fieldset class="role-selector" aria-label="Select your role">
          <legend style="font-weight:700;margin-bottom:12px;font-size:14px;">I am a...</legend>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            <div>
              <input type="radio" name="role" id="role-parent" value="parent" checked>
              <label for="role-parent" class="role-card">
                <div class="role-card__icon" aria-hidden="true">👨‍👩‍👧</div>
                <div class="role-card__label">Parent</div>
              </label>
            </div>
            <div>
              <input type="radio" name="role" id="role-therapist" value="therapist">
              <label for="role-therapist" class="role-card">
                <div class="role-card__icon" aria-hidden="true">👩‍⚕️</div>
                <div class="role-card__label">Therapist</div>
              </label>
            </div>
          </div>
        </fieldset>

        <div class="form-group">
          <label for="name">Full name *</label>
          <input type="text" id="name" name="name" class="form-control" required aria-required="true">
        </div>
        <div class="form-group">
          <label for="email">Email *</label>
          <input type="email" id="email" name="email" class="form-control" required aria-required="true">
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="password">Password *</label>
            <input type="password" id="password" name="password" class="form-control" required minlength="6" aria-required="true">
          </div>
          <div class="form-group">
            <label for="confirmPassword">Confirm password *</label>
            <input type="password" id="confirmPassword" name="confirmPassword" class="form-control" required aria-required="true">
          </div>
        </div>

        <div id="parent-fields" class="role-fields active">
          <div class="form-group">
            <label for="phone">Phone number</label>
            <input type="tel" id="phone" name="phone" class="form-control">
          </div>
          <div class="form-group">
            <label for="emergencyContact">Emergency contact</label>
            <input type="text" id="emergencyContact" name="emergencyContact" class="form-control" placeholder="Name and phone number">
          </div>
        </div>

        <div id="therapist-fields" class="role-fields">
          <div class="form-group">
            <label for="licenseNo">License number *</label>
            <input type="text" id="licenseNo" name="licenseNo" class="form-control">
          </div>
          <div class="form-group">
            <label for="specialties">Specialties</label>
            <select id="specialties" name="specialties" class="form-control" multiple size="4" aria-describedby="specialties-help">
              <option value="Speech Therapy">Speech Therapy</option>
              <option value="Behavioral Therapy">Behavioral Therapy</option>
              <option value="Occupational Therapy">Occupational Therapy</option>
              <option value="Play Therapy">Play Therapy</option>
              <option value="Social Skills">Social Skills</option>
              <option value="Family Counseling">Family Counseling</option>
            </select>
            <small id="specialties-help" style="color:var(--color-text-muted);font-size:12px;">Hold Ctrl/Cmd to select multiple</small>
          </div>
          <div class="form-group">
            <label for="yearsExperience">Years of experience</label>
            <input type="number" id="yearsExperience" name="yearsExperience" class="form-control" min="0" max="50">
          </div>
        </div>

        <div class="form-group">
          <label class="form-check">
            <input type="checkbox" name="terms" id="terms" required aria-required="true">
            I agree to the <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a>
          </label>
        </div>

        <button type="submit" class="btn btn-teal btn-full">Create account</button>
      </form>

      <p class="auth-footer">
        Already have an account? <a href="/login"><strong>Sign in</strong></a>
      </p>
    </div>
  </div>

  <script src="/js/main.js"></script>
  <script src="/js/register.js"></script>
</body>
</html>
